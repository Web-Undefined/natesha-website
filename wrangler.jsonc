{
  "compatibility_date": "2026-06-15",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "natesha-website",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "KEYSTATIC_GITHUB_CLIENT_ID": "paste-your-client-id-here"
  }
}